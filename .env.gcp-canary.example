COMPOSE_PROJECT_NAME=red-alerts-notifier
SHARED_DOCKER_NETWORK=red-alerts_default
POLLER_STATE_VOLUME=red-alerts-notifier-poller-state
TELEGRAM_BOT_STATE_VOLUME=red-alerts-notifier-telegram-bot-state

# Reuse the existing GCP Evolution and Postgres containers on the shared network.
EVOLUTION_URL=http://evolution-api:8080
EVOLUTION_API_KEY=replace-with-existing-evolution-api-key
EVOLUTION_INSTANCE=default
EVOLUTION_FALLBACK_INSTANCE=
POLLER_DATABASE_URL=postgresql://postgres:postgres@evolution-db:5432/evolution
POLLER_DATABASE_SCHEMA=poller_canary

# Canary notifications go to both WhatsApp and Telegram.
# Telegram delivery targets use the `telegram:<chat_id>` form.
WHATSAPP_TARGETS=972500000001,telegram:123456789
NOTIFIER_ACTIVE_TRANSPORTS=whatsapp,telegram

# Reuse the Telegram bot only after stopping the tmm telegram-bot process.
TELEGRAM_BOT_TOKEN=replace-with-tmm-telegram-bot-token
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_POLL_TIMEOUT_SECONDS=50
TELEGRAM_POLL_RETRY_MS=5000
POLLER_INTERNAL_URL=http://poller:3000

ACTIVE_SOURCES=oref_alerts,oref_history,oref_mqtt,tzevaadom
OREF_MQTT_ENABLED=true
TZEVAADOM_ENABLED=true
OREF_ALERTS_POLL_INTERVAL_MS=1000
OREF_HISTORY_POLL_INTERVAL_MS=5000
POLL_INTERVAL_MS=10000

ALERT_SINKS=notification_outbox
DELIVERY_ENABLED=true
SOURCE_EVENT_LEDGER_ENABLED=true

ALERT_LOCATIONS=חיפה
LOG_LEVEL=info
LOG_SUPPRESSION_INTERVAL_MS=60000

DEBUG_CAPTURE_ENABLED=false
DEBUG_CAPTURE_TTL_HOURS=0
DEBUG_CAPTURE_MAX_ENTRIES=50000

PAGERDUTY_ROUTING_KEY=
PAGERDUTY_EVENTS_URL=https://events.pagerduty.com/v2/enqueue
PAGERDUTY_SOURCE=red-alerts/poller
PAGERDUTY_COMPONENT=poller
PAGERDUTY_GROUP=red-alerts
PAGERDUTY_CLASS=ops
PAGERDUTY_WHATSAPP_DISCONNECT_MS=120000
PAGERDUTY_SOURCE_FAILURE_CYCLES=6
PAGERDUTY_POLL_ERROR_CYCLES=3
PAGERDUTY_DB_DISCONNECT_MS=30000
PAGERDUTY_OUTBOX_BACKLOG_MS=60000
PAGERDUTY_NOTIFIER_STALE_MS=45000
PAGERDUTY_TZEVAADOM_DISCONNECT_MS=300000

OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_RESERVE_BATCH=5
OUTBOX_RETRY_BASE_MS=15000
OUTBOX_MAX_ATTEMPTS=8
OUTBOX_PROCESSING_TIMEOUT_MS=30000
OUTBOX_STATUS_REFRESH_MS=15000
OUTBOX_NOTIFY_RECONNECT_DELAY_MS=5000
NOTIFIER_WORKER_ID=gcp-canary

POLLER_PUBLISHED_PORT=3302
POLLER_HOST_IP=127.0.0.1
