EVOLUTION_IMAGE=evoapicloud/evolution-api:latest
EVOLUTION_HOST_IP=127.0.0.1
EVOLUTION_PUBLISHED_PORT=3001
EVOLUTION_SERVER_URL=http://127.0.0.1:3001
EVOLUTION_API_KEY=your-secret-api-key
APP_DB_NAME=red_alerts
APP_DB_USER=postgres
APP_DB_PASSWORD=postgres
# Legacy aliases still work if you already use them:
# EVOLUTION_DB_NAME=evolution
# EVOLUTION_DB_USER=postgres
# EVOLUTION_DB_PASSWORD=postgres
EVOLUTION_REDIS_PREFIX=red_alerts
EVOLUTION_INSTANCE=default
EVOLUTION_FALLBACK_INSTANCE=
EVOLUTION_SESSION_PHONE_CLIENT=Evolution API
EVOLUTION_SESSION_PHONE_NAME=Chrome
POLLER_HOST_IP=127.0.0.1
POLLER_PUBLISHED_PORT=3000
POLLER_DATABASE_URL=postgresql://postgres:postgres@app-db:5432/red_alerts
# Comma-separated targets. Supports direct numbers and full group chat IDs.
# WHATSAPP_TARGETS=972501234567,1201234567890@g.us
WHATSAPP_TARGETS=
# Legacy single-target settings; ignored when WHATSAPP_TARGETS is set.
WHATSAPP_CHAT_ID=
# WHATSAPP_NUMBER=972501234567
WHATSAPP_NUMBER=
# Optional test-only targets for `/simulate useTestTarget=true`.
# Supports WhatsApp targets and Telegram targets like `telegram:123456789`.
TEST_NOTIFICATION_TARGETS=
LOG_LEVEL=info
LOG_SUPPRESSION_INTERVAL_MS=60000
# Set to true after configuring targets and verifying the setup.
DELIVERY_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_POLL_TIMEOUT_SECONDS=50
TELEGRAM_POLL_RETRY_MS=5000
POLLER_INTERNAL_URL=http://poller:3000
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_RESERVE_BATCH=5
OUTBOX_MAX_CONCURRENCY=
OUTBOX_RETRY_BASE_MS=15000
OUTBOX_MAX_ATTEMPTS=8
OUTBOX_PROCESSING_TIMEOUT_MS=30000
OUTBOX_STATUS_REFRESH_MS=15000
OUTBOX_NOTIFY_RECONNECT_DELAY_MS=5000
# `notification_outbox` is the full-stack default. Use `log` for poller-only deployments.
ALERT_SINKS=notification_outbox
NOTIFIER_ACTIVE_TRANSPORTS=
NOTIFIER_WORKER_ID=
# Sources are composable. OREF MQTT is the main source and is enabled by default.
# The MQTT path follows the observed upstream topic `com.alert.meserhadash`.
ACTIVE_SOURCES=oref_mqtt,tzevaadom,oref_alerts,oref_history
OREF_MQTT_ENABLED=false
OREF_MQTT_RECONNECT_MS=5000
OREF_MQTT_RAW_LOG_ENABLED=false
OREF_MQTT_RAW_LOG_MAX_ENTRIES=500
TZEVAADOM_RECONNECT_MS=5000
TZEVAADOM_RAW_LOG_ENABLED=false
TZEVAADOM_RAW_LOG_MAX_ENTRIES=500
DEBUG_CAPTURE_ENABLED=true
DEBUG_CAPTURE_TTL_HOURS=0
# Raw OREF captures are deduped and capped by DEBUG_CAPTURE_MAX_ENTRIES.
DEBUG_CAPTURE_MAX_ENTRIES=50000
PAGERDUTY_ROUTING_KEY=
PAGERDUTY_EVENTS_URL=https://events.pagerduty.com/v2/enqueue
PAGERDUTY_SOURCE=red-alerts/poller
PAGERDUTY_COMPONENT=poller
PAGERDUTY_GROUP=red-alerts
PAGERDUTY_CLASS=ops
PAGERDUTY_WHATSAPP_DISCONNECT_MS=120000
PAGERDUTY_SOURCE_FAILURE_CYCLES=6
PAGERDUTY_POLL_ERROR_CYCLES=3
PAGERDUTY_DB_DISCONNECT_MS=30000
PAGERDUTY_OUTBOX_BACKLOG_MS=60000
PAGERDUTY_NOTIFIER_STALE_MS=45000
PAGERDUTY_TZEVAADOM_DISCONNECT_MS=300000
POLL_INTERVAL_MS=10000
OREF_ALERTS_POLL_INTERVAL_MS=2000
OREF_HISTORY_POLL_INTERVAL_MS=10000
ALERT_LOCATIONS=
